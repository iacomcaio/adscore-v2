generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String      @id @default(cuid())
  name            String?
  email           String?     @unique
  image           String?
  password        String?
  metaToken       String?     @db.Text
  metaTokenExp    DateTime?
  metaUserId      String?
  selectedAccount String?
  analyses        Analysis[]
  createdAt       DateTime    @default(now())
}

model Analysis {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  accountId    String
  period       String
  adsCount     Int
  winnersCount Int
  losersCount  Int
  resultJson   Json
  createdAt    DateTime @default(now())
}

model Transcription {
  id        String   @id @default(cuid())
  videoId   String   @unique
  full      String   @db.Text
  hook      String?  @db.Text
  meio      String?  @db.Text
  cta       String?  @db.Text
  createdAt DateTime @default(now())
}
